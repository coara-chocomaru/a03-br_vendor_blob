<?xml version="1.0" encoding="utf-8"?>
<PowerHintService>
    <BootUp level="0" enable="1">
        <scenario>
            <boot>boot_up</boot>
        </scenario>
        <action>
            <cpu>
                <unit id="0">
                    <minfreq>100%</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>interactive</governor>
                </unit>
            </cpu>
            <cpuhotplug>
                <minOnline>4</minOnline>
            </cpuhotplug>
            <ddr>
                <minfreq>100%</minfreq>
                <maxfreq>100%</maxfreq>
            </ddr>
        </action>
    </BootUp>
    <BootComplete level="0" enable="1">
        <scenario>
            <boot>boot_complete</boot>
        </scenario>
        <action>
            <cpu>
                <unit id="0">
                    <minfreq>0%</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>interactive</governor>
                    <hispeed_freq>1057000</hispeed_freq>
                </unit>
            </cpu>
            <gpu>
                <unit id="0">
                    <minfreq>0%</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>ondemand</governor>
                </unit>
                <unit id="1">
                    <minfreq>0%</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>ondemand</governor>
                </unit>
            </gpu>
            <ddr>
                <minfreq>0%</minfreq>
                <maxfreq>100%</maxfreq>
            </ddr>
        </action>
    </BootComplete>
    <VideoOff level="0" enable="1">
        <scenario>
            <media>
                <state>off</state>
            </media>
        </scenario>
        <action>
            <vpu>
                <unit id="0">
                    <minfreq>0%</minfreq>
                    <maxfreq>100%</maxfreq>
                </unit>
            </vpu>
            <vpu>
                <unit id="1">
                    <setspeed>416000</setspeed>
                </unit>
            </vpu>
        </action>
    </VideoOff>
    <ScreenOn level="0" enable="1">
        <scenario>
            <screen>screen_on</screen>
        </scenario>
        <action>
            <cpuhotplug>
                <minOnline>1</minOnline>
            </cpuhotplug>
        </action>
    </ScreenOn>
    <AudioPlay level="0" enable="1">
        <scenario>
            <screen>screen_off</screen>
        </scenario>
        <action>
            <cpu>
                <unit id="0">
                    <minfreq>624000</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>interactive</governor>
                </unit>
            </cpu>
            <cpuhotplug>
                <minOnline>1</minOnline>
            </cpuhotplug>
            <ddr>
                <minfreq>0%</minfreq>
                <maxfreq>528000</maxfreq>
            </ddr>
        </action>
    </AudioPlay>
    <Game level="0" enable="1">
        <scenario>
            <foreground_task>game</foreground_task>
        </scenario>
        <action>
            <cpu>
                <unit id="0">
                    <minfreq>312000</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>conservative</governor>
                    <down_threshold>60</down_threshold>
                    <up_threshold>95</up_threshold>
                </unit>
            </cpu>
        </action>
    </Game>
    <Benchmark level="0" enable="1">
        <scenario>
            <foreground_task>benchmark</foreground_task>
        </scenario>
        <action>
            <cpu>
                <unit id="0">
                    <minfreq>100%</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>interactive</governor>
                </unit>
            </cpu>
            <cpuhotplug>
                <minOnline>4</minOnline>
            </cpuhotplug>
            <gpu>
                <unit id="0">
                    <minfreq>100%</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>ondemand</governor>
                </unit>
                <unit id="1">
                    <minfreq>100%</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>ondemand</governor>
                </unit>
            </gpu>
            <ddr>
                <minfreq>100%</minfreq>
                <maxfreq>100%</maxfreq>
            </ddr>
        </action>
    </Benchmark>
    <FMOn level="0" enable="1">
        <scenario>
            <fm>enable</fm>
        </scenario>
        <action>
          <keypad>
            <wakeup>enabled</wakeup>
            <path>/sys/devices/platform/soc.1/d4000000.apb/pxa27x-keypad/power/wakeup</path>
          </keypad>
        </action>
    </FMOn>
    <CallIn level="0" enable="1">
        <scenario>
            <phone>offhook</phone>
            <fm>disable</fm>
        </scenario>
        <action>
          <keypad>
            <wakeup>enabled</wakeup>
            <path>/sys/devices/platform/soc.1/d4000000.apb/pxa27x-keypad/power/wakeup</path>
          </keypad>
        </action>
    </CallIn>
    <CallIdle level="0" enable="0">
        <scenario>
            <phone>idle</phone>
            <fm>disable</fm>
        </scenario>
        <action>
          <shcmd>
            <exec>echo disabled > /sys/devices/platform/soc.2/d4000000.apb/pxa27x-keypad/power/wakeup</exec>
          </shcmd>
        </action>
    </CallIdle>
    <CPUOverheat level="0" enable="0">
        <scenario>
            <thermal>thsens_cpu>0</thermal>
        </scenario>
        <action>
            <cpuhotplug>
                <maxOnline>2</maxOnline>
            </cpuhotplug>
            <gpu>
                <unit id="0">
                    <minfreq>0%</minfreq>
                    <maxfreq>50%</maxfreq>
                    <governor>ondemand</governor>
                </unit>
                <unit id="1">
                    <minfreq>0%</minfreq>
                    <maxfreq>50%</maxfreq>
                    <governor>ondemand</governor>
                </unit>
            </gpu>
        </action>
    </CPUOverheat>
    <GCOverheat level="0" enable="0">
        <scenario>
            <thermal>thsens_gc>0</thermal>
        </scenario>
        <action>
            <gpu>
                <unit id="0">
                    <minfreq>0%</minfreq>
                    <maxfreq>50%</maxfreq>
                    <governor>ondemand</governor>
                </unit>
                <unit id="1">
                    <minfreq>0%</minfreq>
                    <maxfreq>50%</maxfreq>
                    <governor>ondemand</governor>
                </unit>
            </gpu>
        </action>
    </GCOverheat>
    <VPUOverheat level="0" enable="0">
        <scenario>
            <thermal>thsens_vpu>0</thermal>
        </scenario>
        <action>
            <vpu>
                <unit id="0">
                    <setspeed>312000</setspeed>
                </unit>
            </vpu>
            <vpu>
                <unit id="1">
                    <setspeed>312000</setspeed>
                </unit>
            </vpu>
        </action>
    </VPUOverheat>
    <Rotation level="0" enable="1">
        <scenario>
            <rotation>enable</rotation>
        </scenario>
        <action>
            <cpu>
                <unit id="0">
                    <minfreq>797000</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>interactive</governor>
                </unit>
            </cpu>
            <gpu>
                <unit id="0">
                    <minfreq>416000</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>ondemand</governor>
                </unit>
                <unit id="1">
                    <minfreq>312000</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>ondemand</governor>
                </unit>
            </gpu>
            <ddr>
                <minfreq>312000</minfreq>
                <maxfreq>100%</maxfreq>
            </ddr>
        </action>
    </Rotation>
    <AppLaunch level="0" enable="1">
        <scenario>
            <app_launch>enable</app_launch>
        </scenario>
        <action>
            <cpu>
                <unit id="0">
                    <minfreq>100%</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>interactive</governor>
                </unit>
            </cpu>
            <cpuhotplug>
                <minOnline>4</minOnline>
            </cpuhotplug>
            <gpu>
                <unit id="0">
                    <minfreq>100%</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>ondemand</governor>
                </unit>
                <unit id="1">
                    <minfreq>100%</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>ondemand</governor>
                </unit>
            </gpu>
            <ddr>
                <minfreq>100%</minfreq>
                <maxfreq>100%</maxfreq>
            </ddr>
        </action>
    </AppLaunch>
    <BrowserNormal level="0" enable="0">
        <scenario>
            <browser>normal</browser>
        </scenario>
        <action>
            <cpu>
                <unit id="0">
                    <minfreq>797000</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>interactive</governor>
                </unit>
            </cpu>
            <ddr>
                <minfreq>312000</minfreq>
                <maxfreq>100%</maxfreq>
            </ddr>
        </action>
    </BrowserNormal>
    <BrowserScript level="0" enable="0">
        <scenario>
            <browser>script</browser>
        </scenario>
        <action>
            <cpu>
                <unit id="0">
                    <minfreq>1057000</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>interactive</governor>
                </unit>
            </cpu>
            <ddr>
                <minfreq>400000</minfreq>
                <maxfreq>100%</maxfreq>
            </ddr>
        </action>
    </BrowserScript>
    <BrowserBench level="0" enable="0">
        <scenario>
            <browser>bench</browser>
        </scenario>
        <action>
            <cpu>
                <unit id="0">
                    <minfreq>100%</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>interactive</governor>
                </unit>
            </cpu>
            <gpu>
                <unit id="0">
                    <minfreq>100%</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>ondemand</governor>
                </unit>
                <unit id="1">
                    <minfreq>100%</minfreq>
                    <maxfreq>100%</maxfreq>
                    <governor>ondemand</governor>
                </unit>
            </gpu>
            <ddr>
                <minfreq>100%</minfreq>
                <maxfreq>100%</maxfreq>
            </ddr>
        </action>
    </BrowserBench>
</PowerHintService>
